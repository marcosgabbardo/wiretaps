# wiretaps environment configuration
# Copy to .env and fill in your values

# Proxy target (the LLM API to forward requests to)
# WIRETAPS_TARGET=https://api.openai.com

# API server port
# WIRETAPS_API_PORT=8899

# Proxy server port
# WIRETAPS_PROXY_PORT=8080

# Host to bind to
# WIRETAPS_HOST=127.0.0.1

# Session ID (set automatically by `wiretaps run`)
# WIRETAPS_SESSION_ID=

# URL of the wiretaps daemon (used by interceptors)
# WIRETAPS_URL=http://127.0.0.1:8899

# Frontend: API URL for the Next.js dashboard
NEXT_PUBLIC_API_URL=http://localhost:8899
